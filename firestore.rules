rules_version = '2';

// Canonical opsagent-prod Firestore rules.
//
// IMPORTANT: this Firestore database is SHARED by every app under the
// opsagent-prod GCP project — lead-pipeline, trainer (claude-architect-training),
// future apps. Whichever app deploys `firestore:rules` last wins, replacing
// the prior ruleset entirely. To prevent cross-app overwrites, this file
// MUST contain the union of every app's collection rules.
//
// If you add a new app under opsagent-prod, append its rules here AND keep
// this file in sync across all repos that may `firebase deploy --only firestore:rules`.
//
// Apps + their collections:
//
//   lead-pipeline  →  leads/{*}, leads/{*}/shares/{*}, briefings/{*}, allowlist/{*}
//   trainer        →  questions/{*}, users/{*}, (attempts/* writes via Admin SDK only)
//
// History:
//   - 2026-05-28: merged trainer's `questions/{*}` + `users/{*}` blocks into
//     the lead-pipeline base ruleset. Previously the trainer's rules existed
//     only in its repo and got silently overwritten on every lead-pipeline deploy.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── lead-pipeline helpers ──────────────────────────────────────────
    function isAllowlistedUser() {
      return request.auth != null && request.auth.token.allowlisted == true;
    }
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }
    function isOwner(data) {
      return request.auth != null && request.auth.token.email == data.ownerEmail;
    }
    function isShared(data) {
      return request.auth != null
        && data.sharedWith is list
        && data.sharedWith.hasAny([request.auth.token.email]);
    }

    // ── lead-pipeline: leads ───────────────────────────────────────────
    match /leads/{leadId} {
      allow read:   if isAllowlistedUser()
                    && (isOwner(resource.data) || isShared(resource.data) || isAdmin());
      allow create: if isAllowlistedUser()
                    && request.resource.data.ownerEmail == request.auth.token.email
                    && request.resource.data.keys().hasAll(['name','stage','heat','date','ownerEmail']);
      allow update: if isAllowlistedUser()
                    && (isOwner(resource.data) || isShared(resource.data))
                    && request.resource.data.ownerEmail == resource.data.ownerEmail
                    && (
                         isOwner(resource.data)
                         || request.resource.data.sharedWith == resource.data.sharedWith
                       );
      allow delete: if isAllowlistedUser() && isOwner(resource.data);
    }

    // ── lead-pipeline: lead shares (admin-SDK only) ────────────────────
    match /leads/{leadId}/shares/{shareId} {
      allow read, write: if false;
    }

    // ── lead-pipeline: briefings ────────────────────────────────────────
    match /briefings/{briefingId} {
      allow read:   if isAllowlistedUser() && isOwner(resource.data);
      allow create: if isAllowlistedUser()
                    && request.resource.data.ownerEmail == request.auth.token.email;
      allow update, delete: if isAllowlistedUser() && isOwner(resource.data);
    }

    // ── lead-pipeline: allowlist ───────────────────────────────────────
    match /allowlist/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // ── trainer: question bank (R2) ────────────────────────────────────
    // Authed clients (including anonymous sign-ins) can READ questions.
    // Writes flow through Admin SDK only (seedQuestions callable + npm run seed).
    match /questions/{qId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    // ── trainer: user profile docs (card 1jpqYSeg) ─────────────────────
    // Frontend writes the profile doc directly after sign-up succeeds.
    // Each authenticated, non-anonymous user owns exactly their own doc.
    // Anonymous users are denied (they have no profile yet).
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ── trainer: attempts (Admin SDK only) ──────────────────────────────
    // The `api` HTTPS function (Functions Gen 2) writes attempts on behalf
    // of authed clients (anon or not). Direct client writes are blocked
    // so a leaked anon ID token can't pollute the collection.
    match /attempts/{path=**} {
      allow read, write: if false;
    }

    // ── catch-all deny ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
